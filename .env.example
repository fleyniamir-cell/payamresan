# Server Configuration
# Port for backend API server (default: 5174)
SERVER_PORT=5174
# Port for serving frontend client (default: 80)
CLIENT_PORT=80

# Application Settings
# Environment mode: production or development (default: production)
APP_ENV=production
# Enable debug logging: true or false (default: false)
APP_DEBUG=false
# Allow new user registration via UI: true or false (default: true)
SIGN_UP=true

# File Upload Settings
# Enable file uploads: true or false (default: true)
FILE_UPLOAD=true
# Maximum size per file in MB (default: 25)
FILE_UPLOAD_MAX_SIZE_MB=25
# Maximum total size for all files in a message in MB (default: 75)
FILE_UPLOAD_MAX_TOTAL_SIZE_MB=75
# Maximum number of files per message (default: 10)
FILE_UPLOAD_MAX_FILES=10
# Transcode videos to H.264/AAC MP4: true or false (default: true)
FILE_UPLOAD_TRANSCODE_VIDEOS=true

# Message Retention
# Days to keep message files before auto-deletion, 0 = keep forever (default: 7)
MESSAGE_FILE_RETENTION=7
# Days to keep message text before auto-deletion, 0 = keep forever (default: 0)
MESSAGE_TEXT_RETENTION=0
# Maximum characters per message (default: 4000)
MESSAGE_MAX_CHARS=4000

# User Limits
# Maximum characters for display name (default: 24)
NICKNAME_MAX_CHARS=24
# Maximum characters for username (default: 16)
USERNAME_MAX_CHARS=16

# Chat Client Settings
# Hours to cache chat data (default: 24)
CHAT_CACHE_TTL=24
# Maximum messages to fetch from server (default: 60)
CHAT_MESSAGE_FETCH_LIMIT=60
# Messages per page in UI (default: 60)
CHAT_MESSAGE_PAGE_SIZE=60
# Milliseconds between chat list refreshes (default: 20000)
CHAT_LIST_REFRESH_INTERVAL=20000
# Milliseconds between presence pings (default: 5000)
CHAT_PRESENCE_PING_INTERVAL=5000
# Milliseconds between checking peer presence (default: 3000)
CHAT_PEER_PRESENCE_POLL_INTERVAL=3000
# Milliseconds between health checks (default: 10000)
CHAT_HEALTH_CHECK_INTERVAL=10000
# Milliseconds to wait before SSE reconnect (default: 2000)
CHAT_SSE_RECONNECT_DELAY=2000
# Maximum search results to return (default: 5)
CHAT_SEARCH_MAX_RESULTS=5
# Maximum MB for voice waveform decoding (default: 5)
CHAT_VOICE_WAVEFORM_MAX_DECODE_MB=5
# Maximum seconds for voice waveform decoding (default: 480)
CHAT_VOICE_WAVEFORM_MAX_DECODE_SECONDS=480

# Chat Pending Message Settings
# Milliseconds before text message times out (default: 300000)
CHAT_PENDING_TEXT_TIMEOUT=300000
# Milliseconds before file message times out (default: 1200000)
CHAT_PENDING_FILE_TIMEOUT=1200000
# Milliseconds between retry attempts (default: 4000)
CHAT_PENDING_RETRY_INTERVAL=4000
# Milliseconds between status checks (default: 1000)
CHAT_PENDING_STATUS_CHECK_INTERVAL=1000

# Remote Channel
# Enable remote channel mirroring: true or false (default: false)
REMOTE_CHANNEL=false
# Allow channel owners to enable Remote Channel in UI: true or false (default: true)
REMOTE_CHANNEL_UI=true
# Allow stream media files option in UI: true or false (default: true)
REMOTE_CHANNEL_MEDIA_STREAM=true
# Telegram API ID (default: 0)
REMOTE_CHANNEL_TELEGRAM_API_ID=0
# Telegram API hash (default: empty)
REMOTE_CHANNEL_TELEGRAM_API_HASH=""
# Telegram session string from configuration script (default: empty)
REMOTE_CHANNEL_TELEGRAM_SESSION_STRING=""
# HTTPS proxy URL for Telegram MTProto connection, optional (default: empty)
# Supports: http://, https://, socks4://, socks5://, mtproxy://
REMOTE_CHANNEL_TELEGRAM_PROXY_URL=""
# HTTPS proxy URL for Songbird server-to-server requests, optional (default: empty)
REMOTE_CHANNEL_SONGBIRD_PROXY_URL=""
# Milliseconds between Telegram polls (default: 5000)
REMOTE_CHANNEL_POLL_INTERVAL_MS=5000
# Maximum messages per Telegram poll (default: 50)
REMOTE_CHANNEL_TELEGRAM_POLL_LIMIT=50
# Milliseconds between queue processing (default: 1000)
REMOTE_CHANNEL_QUEUE_INTERVAL_MS=1000
# Maximum retry attempts for failed jobs (default: 10)
REMOTE_CHANNEL_QUEUE_MAX_ATTEMPTS=10
# Jobs to process per batch (default: 10)
REMOTE_CHANNEL_QUEUE_BATCH_SIZE=10
# Concurrent jobs to process (default: 3)
REMOTE_CHANNEL_QUEUE_CONCURRENCY=3
# Milliseconds before lock is considered stale (default: 300000)
REMOTE_CHANNEL_QUEUE_STALE_LOCK_MS=300000

# Security & Encryption
# Encryption key for storage, auto-generated if empty (default: empty)
STORAGE_ENCRYPTION_KEY=""

# Push Notifications
# VAPID public key, auto-generated if empty (default: empty)
VAPID_PUBLIC_KEY=""
# VAPID private key, auto-generated if empty (default: empty)
VAPID_PRIVATE_KEY=""
# VAPID subject email or URL (default: mailto:admin@example.com)
VAPID_SUBJECT="mailto:admin@example.com"
# HTTPS proxy URL for push notifications, optional (default: empty)
PUSH_PROXY_URL=""
