{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [
          { "subject": "*\\[major release\\]*", "release": "major" },
          { "subject": "*\\[minor release\\]*", "release": "minor" },
          { "subject": "*\\[patch release\\]*", "release": "patch" },
          { "type": "*", "release": false },
          { "subject": "*", "release": false }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [{ "path": "dist/*.zip", "label": "Distribution" }],
        "failOnIssueNotFound": false
      }
    ]
  ]
}
