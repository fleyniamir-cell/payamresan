{
  "name": "songbird",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bllackbull/songbird.git"
  },
  "bugs": {
    "url": "https://github.com/bllackbull/songbird/issues"
  },
  "homepage": "https://github.com/bllackbull/songbird#readme",
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "build": "npm --prefix client run build",
    "preview": "npm --prefix client run preview",
    "start": "npm --prefix server run start",
    "remote:configure": "node server/scripts/configure-remote-channel.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "concurrently": "^10.0.3",
    "npm": "^11.16.0",
    "semantic-release": "^25.0.3",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "volta": {
    "node": "24.11.1",
    "npm": "11.16.0"
  }
}
